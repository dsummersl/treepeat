---
import Layout from '../layouts/Layout.astro';

interface Props {
  heading: string;
  summary: string;
}

const { heading, summary } = Astro.props;

function buildPageTitle(heading: string): string {
  const prefix = 'Site';
  return `${prefix} - ${heading}`;
}

function truncateDescription(summary: string): string {
  const maxLen = 160;
  return summary.length > maxLen ? summary.slice(0, maxLen) : summary;
}
---

<Layout title={buildPageTitle(heading)}>
  <main>
    <h1>{heading}</h1>
    <p>{truncateDescription(summary)}</p>
  </main>
</Layout>
